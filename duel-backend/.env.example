# Server
PORT=8000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/duel_db

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# JWT
ACCESS_TOKEN_SECRET=your-access-token-secret-here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
REFRESH_TOKEN_EXPIRY=7d

# Problem Service
PROBLEM_SERVICE_URL=http://localhost:3000
PROBLEM_SERVICE_KEY=your-service-key-here

# Judge0 API (get free key from RapidAPI)
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-judge0-rapidapi-key-here

